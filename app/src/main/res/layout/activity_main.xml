<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Uses FCM — no persistent connection required"
            android:textSize="13sp"
            android:alpha="0.55"
            android:layout_marginBottom="28dp"/>

        <!-- SMS status -->
        <TextView
            android:id="@+id/tv_sms_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ui_sms_permission_missing"
            android:textSize="15sp"
            android:padding="14dp"
            android:background="#F0F4FF"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_request_permissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ui_btn_request_permissions"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_battery_optimization"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ui_btn_battery_optimization"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="24dp"/>

        <!-- FCM token section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ui_token_label"
            android:textSize="13sp"
            android:textStyle="bold"
            android:alpha="0.7"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tv_fcm_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ui_token_loading"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ui_btn_copy_token"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="24dp"/>

        <!-- Instructions -->
        <TextView
            android:id="@+id/tv_instructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ui_instructions"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.5"
            android:alpha="0.65"/>

    </LinearLayout>
</ScrollView>
